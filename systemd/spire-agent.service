[Unit]
Description=SPIRE Agent
Documentation=https://spiffe.io/docs/latest/spire-about/spire-concepts/
After=network-online.target docker.service spire-server.service
Wants=network-online.target
Requires=spire-server.service

[Service]
Type=simple
User=spire-agent
Group=spire-agent

ExecStart=/usr/local/sbin/run-spire-agent

Restart=on-failure
RestartSec=5

RuntimeDirectory=spire-agent
RuntimeDirectoryMode=0750

UMask=0027
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true

[Install]
WantedBy=multi-user.target