SPIRE_SERVER_SOCKET=/run/spire/server/private/api.sock
SPIRE_SERVER_SOCKET_DIR=/run/spire/server/private
SPIRE_AGENT_SOCKET=/run/spire/agent/agent.sock
SPIRE_AGENT_SOCKET_DIR=/run/spire/agent
SPIRE_AGENT_BINARY=/opt/spire/bin/spire-agent
SPIRE_SERVER_BINARY=/opt/spire/bin/spire-server
SPIRE_AGENT_JOIN_TOKEN_FILE=/var/lib/spire/agent/join-token
SPIRE_AGENT_SPIFFE_ID_PREFIX=spiffe://example.org/spire/agent/join_token/
SPIRE_AGENT_SPIFFE_ID_FILE=/var/lib/spire/agent/agent-spiffe-id

KV_SPIFFE_ID=spiffe://example.org/workload/kv-store
KV_CONTAINER_NAME=kv-store
KV_WORKLOAD_LABEL_KEY=spire.workload
KV_WORKLOAD_LABEL_VALUE=kv-store
KV_APP_LABEL_KEY=spire.app
KV_APP_LABEL_VALUE=key-store-demo
KV_COMPONENT_LABEL_KEY=spire.component
KV_COMPONENT_LABEL_VALUE=key-value-api
KV_SELECTOR_1=docker:label:spire.workload:kv-store
KV_SELECTOR_2=docker:label:spire.app:key-store-demo
KV_SELECTOR_3=docker:label:spire.component:key-value-api
KEY_STORE_IMAGE=arthurgb469/key-store-demo:0.1.0
DEMO_EVIDENCE_DIR=/var/lib/spire-demo/evidence
KV_EVIDENCE_DIR=/var/lib/spire-demo/evidence/kv-store

SPIRE_MCP_IMAGE=arthurgb469/spire-mcp:0.1.1
SPIRE_MCP_CONTAINER_NAME=spire-mcp
